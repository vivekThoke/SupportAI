## ============================================================================
## BUILD ARTIFACTS
## ============================================================================
# Ignore build output directories
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/

## ============================================================================
## IDE & EDITOR FILES
## ============================================================================
# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# User-specific files
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains Rider
.idea/
*.sln.iml

## ============================================================================
## ASP.NET CORE SPECIFIC
## ============================================================================
# Ignore local configuration files that may contain secrets
# Keep appsettings.json, but ignore environment overrides
**/appsettings.Development.json
**/appsettings.Local.json
**/appsettings.Production.json

# Environment variables file
.env

# Logs
*.log
local_log/

## ============================================================================
## TESTING & DEPENDENCIES
## ============================================================================
# Test results
TestResults/

# NuGet Packages (if strictly not using local packages)
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# allow the build to find the 'build' folder in packages
!**/packages/build/
# If using central package management
!**/packages.config

## ============================================================================
## OS GENERATED FILES
## ============================================================================
# Mac
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini